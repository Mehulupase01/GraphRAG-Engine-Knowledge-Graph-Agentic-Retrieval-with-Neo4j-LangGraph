GRAPH_RAG_ENV=development
GRAPH_RAG_DATA_DIR=./data
GRAPH_RAG_LOG_LEVEL=INFO
GRAPH_RAG_MODEL_BACKEND=local
GRAPH_RAG_OPENAI_API_KEY=
GRAPH_RAG_OPENAI_BASE_URL=
GRAPH_RAG_CHAT_MODEL=gpt-4.1-mini
GRAPH_RAG_EMBEDDING_MODEL=text-embedding-3-large
GRAPH_RAG_JUDGE_MODEL=gpt-4.1-mini
GRAPH_RAG_ANTHROPIC_API_KEY=
GRAPH_RAG_ANTHROPIC_BASE_URL=https://api.anthropic.com
GRAPH_RAG_ANTHROPIC_MODEL=claude-sonnet-4-20250514
GRAPH_RAG_ANTHROPIC_VERSION=2023-06-01
GRAPH_RAG_GEMINI_API_KEY=
GRAPH_RAG_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GRAPH_RAG_GEMINI_MODEL=gemini-2.5-flash
GRAPH_RAG_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GRAPH_RAG_LOCAL_CHAT_MODEL=Qwen/Qwen2.5-1.5B-Instruct
GRAPH_RAG_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GRAPH_RAG_LOCAL_DEVICE=auto
GRAPH_RAG_LOCAL_MAX_NEW_TOKENS=384
GRAPH_RAG_LOCAL_TEMPERATURE=0.1
GRAPH_RAG_LOCAL_TRUST_REMOTE_CODE=true
GRAPH_RAG_NEO4J_URI=bolt://localhost:7687
GRAPH_RAG_NEO4J_USER=neo4j
GRAPH_RAG_NEO4J_PASSWORD=change-me-now
GRAPH_RAG_MAX_CHUNK_TOKENS=450
GRAPH_RAG_CHUNK_OVERLAP=80
GRAPH_RAG_VECTOR_DIMENSION=64
GRAPH_RAG_DEFAULT_RETRIEVAL_K=8
GRAPH_RAG_AGENT_MAX_REWRITES=2
GRAPH_RAG_AGENT_MAX_GRAPH_HOPS=2
GRAPH_RAG_EVAL_CASES_PATH=./configs/eval_cases.json
